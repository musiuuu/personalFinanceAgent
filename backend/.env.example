# Copy to .env — everything is optional; the app runs fully offline without it.

# Anthropic API (enables LLM routing/planning/explaining + NL→SQL + categorization fallback).
# Without a key the agent uses its deterministic heuristic router/planner and
# template explainer — all engine math is identical either way.
ANTHROPIC_API_KEY=

# Models (cheap for categorization/routing, smart for planning/explanation)
LLM_CHEAP_MODEL=claude-haiku-4-5-20251001
LLM_SMART_MODEL=claude-sonnet-4-6

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=finance-agent

# Engine knobs
SAFETY_BUFFER_MINOR=5000000        # 50,000 PKR in paisa
FORECAST_LOOKBACK_MONTHS=3
ANOMALY_MAD_K=3.5

DATABASE_URL=sqlite:///finance.db
